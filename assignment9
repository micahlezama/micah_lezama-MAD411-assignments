data class Habit(
    val name: String,
    var isCompleted: Boolean = false,
    val id: Long = System.currentTimeMillis()
)
data class Quote(
    val q: String,
    val a: String,
    val h: String

)

interface QuoteApiService{
    @GET("Quote")
    suspend fun getRandomQuote(): List<Quote>
}
object RetrofitInstance {

    private const val BASE_URL = "https://zenquotes.io/api/"

    val api: QuoteApiService by lazy {
        Retrofit.Builder()
            .baseUrl(BASE_URL)
            .addConverterFactory(GsonConverterFactory.create())
            .build()
            .create(QuoteApiService::class.java)
    }
}
sealed class QuoteUiState {
    object Loading : QuoteUiState()
    data class Success(val quote: List<Quote>) : QuoteUiState()

    data class Error(val message: String) : QuoteUiState()
}

private const val FILE_NAME = "habits.json"
class HabitTrackerViewModel : ViewModel() {




    private val _quoteUiState = MutableStateFlow<QuoteUiState>(QuoteUiState.Loading)
    val quoteUiState: StateFlow<QuoteUiState> = _quoteUiState

    init {
        fetchQuote()
    }
     fun saveHabitsToFile(context: Context, habits: List<Habit>) {
        val gson = Gson()
        val jsonString = gson.toJson(habits)

        val file = File(context.filesDir, FILE_NAME)
        file.writeText(jsonString)
    }
    suspend fun loadHabitsFromFile(context: Context): List<Habit> {
        return withContext(Dispatchers.IO) {
            val file = File(context.filesDir, FILE_NAME)

            if (!file.exists()) {
                return@withContext emptyList<Habit>()
            }

            val jsonString = file.readText()

            val gson = Gson()
            val type = object : TypeToken<List<Habit>>() {}.type

            return@withContext gson.fromJson(jsonString, type)
        }
    }



    fun fetchQuote() {
        viewModelScope.launch {
            _quoteUiState.value = QuoteUiState.Loading


            try {
                val response = RetrofitInstance.api.getRandomQuote()
                _quoteUiState.value = QuoteUiState.Success(response)
            } catch (e: Exception) {
                _quoteUiState.value = QuoteUiState.Error(e.message ?: "Unknown error")
            }
        }
    }
}

