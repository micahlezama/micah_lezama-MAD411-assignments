@Composable
fun HabitTrackerApp() {
    val navController = rememberNavController()

    NavHost(
        navController = navController,
        startDestination = "habit_list"
    ) {
        composable("habit_list") {
            HabitListScreen(navController = navController)
            Button(
                onClick = {
                    val intent = Intent(Intent.ACTION_VIEW, Uri.parse("https://www.google.com"))
                    navController.context.startActivity(intent)
                },
                modifier = Modifier.padding(top = 16.dp)
            ) {
                Text("Open Website")
            }

        }
        composable("habit_detail/{habitName}/{completed}") { backStackEntry ->
            val habitName = backStackEntry.arguments?.getString("habitName")
            val completed = backStackEntry.arguments?.getString("completed") == "true"
            HabitDetailScreen(
                navController = navController,
                habitName = habitName,
                completed = completed
            )
        }
    }
}

@Composable
fun HabitListScreen(navController: NavController) {
    val viewModel: HabitTrackerViewModel = viewModel()

    val context = LocalContext.current
    var habitText by rememberSaveable { mutableStateOf("") }
    var userName by rememberSaveable { mutableStateOf("") }



    val habits = remember { mutableStateListOf<Habit>() }

    val snackbarHostState = remember { SnackbarHostState() }
    val scope = rememberCoroutineScope()

    Scaffold(
        snackbarHost = { SnackbarHost(snackbarHostState) }
    ) { padding ->
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(16.dp)
                .padding(padding)
        ) {
            Text(
                text = "Student Habit Tracker",
                style = MaterialTheme.typography.headlineMedium
            )
            var userName by rememberSaveable { mutableStateOf("")}
            LaunchedEffect(Unit) {
                val sharedPref = context.getSharedPreferences("UserPreferences", Context.MODE_PRIVATE)
                userName = sharedPref.getString("userName", "") ?: ""
            }

            OutlinedTextField(
                value = userName,
                onValueChange = { userName = it },
                label = { Text("Your Name") },
                modifier = Modifier
                    .fillMaxWidth()
                    .padding(top = 12.dp, bottom = 16.dp)
            )
            val context = LocalContext.current

            Button(onClick = {
                val sharedPref = context.getSharedPreferences("UserPreferences", Context.MODE_PRIVATE)
                val editor = sharedPref.edit()
                editor.putString("userName", userName)
                editor.apply()
            }) {
                Text("Save Name")
            }



            QuoteSection()

            HabitInputSection(
                habitText = habitText,
                onHabitTextChange = { habitText = it },
                onAddHabit = {
                    if (habitText.isNotBlank()) {
                        habits.add(Habit(habitText))
                        habitText = ""

                        viewModel.saveHabitsToFile(context, habits)

                        scope.launch {
                            snackbarHostState.showSnackbar("Habit added!")

                        }
                    }

                }
            )

            if (userName.isNotBlank()) {
                Text(
                    text = "Welcome back, $userName!"
                )
            }

            HabitList(
                habits = habits,
                onHabitCompleted = { index ->
                    habits[index] = habits[index].copy(

                        isCompleted = !habits[index].isCompleted

                    )
                    viewModel.saveHabitsToFile(context, habits)
                },
                onHabitDeleted = { index ->
                    habits.removeAt(index)
                    viewModel.saveHabitsToFile(context, habits)
                },
                onHabitClicked = { habit ->
                    navController.navigate(
                        "habit_detail/${habit.name}/${habit.isCompleted}"
                    )
                }
            )
        }
    }
}

@Composable
fun HabitInputSection(
    habitText: String,
    onHabitTextChange: (String) -> Unit,
    onAddHabit: () -> Unit
) {
    var text by rememberSaveable { mutableStateOf(habitText) }
    Column(modifier = Modifier.padding(top = 16.dp)) {
        OutlinedTextField(
            value = text,
            onValueChange = {
                text = it
                onHabitTextChange(it)
            },
            label = { Text("Enter a new habit") },
            modifier = Modifier.padding(bottom = 8.dp)

        )
        FloatingActionButton(onClick = onAddHabit) {
            Text("Add Habit")
        }


    }
}



@Composable
fun HabitList(
    habits: List<Habit>,
    onHabitCompleted: (Int) -> Unit,
    onHabitDeleted: (Int) -> Unit,
    onHabitClicked: (Habit) -> Unit
) {
    LazyColumn(modifier = Modifier.padding(top = 16.dp)) {
        items(
            items = habits,
            key = { habit -> habit.id }
        ) { habit ->
            HabitItem(
                habit = habit,
                onCompleted = { onHabitCompleted(habits.indexOf(habit)) },
                onDelete = { onHabitDeleted(habits.indexOf(habit)) },
                onClick = { onHabitClicked(habit) }
            )
        }
    }
}

@Composable
fun HabitItem(
    habit: Habit,
    onCompleted: () -> Unit,
    onDelete: () -> Unit,
    onClick: () -> Unit
) {
    Row(
        modifier = Modifier
            .fillMaxWidth()
            .padding(vertical = 8.dp),
        horizontalArrangement = Arrangement.SpaceBetween
    ) {
        Text(
            text = habit.name,
            style = if (habit.isCompleted)
                MaterialTheme.typography.bodyLarge.copy(
                    color = MaterialTheme.colorScheme.primary
                )
            else
                MaterialTheme.typography.bodyLarge
        )

        Button(onClick = onCompleted) {
            Text("Completed")
        }

        Button(onClick = onDelete) {
            Text("Delete")
        }

        Button(onClick = onClick) {
            Text("View Details")
        }
    }
}

